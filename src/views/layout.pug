doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Aim Trainer - Bolitas
    link(rel="stylesheet", href="/css/style.css")
  body
    nav
      a.logo(href="/") BOLITAS
      .nav-links
        a(href="/") Inicio
        if username
          if role === 'admin'
            a(href="/admin", style="color: #58a6ff; font-weight: bold;") Panel Admin
          span(style="color: #8b949e") Hola, #{username}
          a(href="/auth/logout", style="color: #f85149") Salir
        else
          a(href="/login") Iniciar Sesión

    main
      block content