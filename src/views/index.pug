extends layout

block content
  .container
    // Hero Section
    section(style="text-align: center; margin-bottom: 5rem; animation: fadeIn 1s ease-out;")
      img(src="/images/logo.png", alt="Bolitas Logo", style="width: 180px; margin-bottom: 2rem; filter: drop-shadow(0 0 20px rgba(88, 166, 255, 0.3));")
      h1(style="font-size: 3.5rem; margin-bottom: 1rem; background: linear-gradient(90deg, #fff, #58a6ff); -webkit-background-clip: text; -webkit-text-fill-color: transparent;") BOLITAS
      p(style="color: #8b949e; font-size: 1.25rem; max-width: 700px; margin: 0 auto 3rem;") 
        | El entrenador de puntería definitivo diseñado para perfeccionar tu precisión, 
        | tiempo de reacción y micro-ajustes en juegos competitivos.

    // Game Selection
    h2(style="text-align: center; margin-bottom: 3rem;") Selecciona tu modo de entrenamiento
    .dashboard-grid
      each m in modes
        .game-card(onclick=`window.location.href='/game/${m.name}'`)
          div(style=`background: ${m.name === 'gridshot' ? 'rgba(88, 166, 255, 0.1)' : 'rgba(248, 81, 73, 0.1)'}; width: 60px; height: 60px; border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem;`)
            span(style="font-size: 2rem;")= m.name === 'gridshot' ? '⚡' : '🎯'
          h2= m.name.charAt(0).toUpperCase() + m.name.slice(1)
          p= m.description
          button(style=`background: ${m.name === 'gridshot' ? '#58a6ff' : '#f85149'}`) Jugar Ahora

    // Ranking Section
    section(style="margin-top: 6rem; padding-bottom: 4rem;")
      h2(style="text-align: center; margin-bottom: 2.5rem;") Hall of Fame (Top 10)
      
      div(style="display: flex; justify-content: center; gap: 1rem; margin-bottom: 2rem;")
        each m in modes
          button(onclick=`loadRanking('${m.name}')`, style="width: auto; padding: 10px 20px;")= m.name.toUpperCase()

      .auth-container(style="max-width: 800px; padding: 2.5rem; background: rgba(13, 17, 23, 0.6); backdrop-filter: blur(10px);")
        table(style="width: 100%; border-collapse: collapse;")
          thead
            tr(style="border-bottom: 2px solid #30363d; color: #8b949e;")
              th(style="padding: 1.2rem; text-align: left;") Rango
              th(style="padding: 1.2rem; text-align: left;") Usuario
              th(style="padding: 1.2rem; text-align: center;") Puntos
              th(style="padding: 1.2rem; text-align: right;") Precisión
          tbody#leaderboard-body
            tr
              td(colspan="4", style="padding: 3rem; text-align: center; color: #8b949e;") Cargando ranking global...
        
        #pagination-controls(style="margin-top: 2rem; display: flex; justify-content: center; gap: 1rem;")

  script.
    let currentMode = 'gridshot';
    let currentPage = 1;

    async function loadRanking(mode = currentMode, page = 1) {
      currentMode = mode;
      currentPage = page;
      try {
        const response = await fetch(`/api/ranking/${mode}?page=${page}&limit=10`);
        const result = await response.json();
        if (result.status === 'success') {
          const tbody = document.getElementById('leaderboard-body');
          tbody.innerHTML = result.data.map((row, index) => `
            <tr style="border-bottom: 1px solid #21262d; transition: background 0.3s;" onmouseover="this.style.background='rgba(88,166,255,0.05)'" onmouseout="this.style.background='transparent'">
              <td style="padding: 1.2rem; text-align: left; color: #8b949e;">#${((page-1)*10) + index + 1}</td>
              <td style="padding: 1.2rem; text-align: left; font-weight: 600;">${row.username}</td>
              <td style="padding: 1.2rem; text-align: center; color: #58a6ff; font-weight: 700;">${row.points}</td>
              <td style="padding: 1.2rem; text-align: right; color: #3fb950;">${row.accuracy}%</td>
            </tr>
          `).join('') || '<tr><td colspan="4" style="padding: 2rem; text-align: center;">Aún no hay leyendas registradas</td></tr>';

          updatePagination(result.pagination);
        }
      } catch (err) {
        console.error(err);
      }
    }

    function updatePagination(pagination) {
      const controls = document.getElementById('pagination-controls');
      controls.innerHTML = '';
      
      if (pagination.pages <= 1) return;

      for (let i = 1; i <= pagination.pages; i++) {
        const btn = document.createElement('button');
        btn.innerText = i;
        btn.style.width = '40px';
        btn.style.padding = '8px';
        btn.style.background = i === pagination.page ? '#58a6ff' : '#21262d';
        btn.onclick = () => loadRanking(currentMode, i);
        controls.appendChild(btn);
      }
    }

    loadRanking();