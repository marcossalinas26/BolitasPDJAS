extends layout

block content
  style.
    /* Asegura que la clase hidden oculte todo de verdad */
    .hidden { display: none !important; }
    #start-overlay, #game-overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(13, 17, 23, 0.9);
      display: flex;
      justify-content: center;
      align-items: center;
      z-index: 10;
    }

  .game-container(style="position: relative;")
    .game-header
      .mode-info
        h2(style="margin: 0; font-size: 1.2rem; color: #8b949e;") MODO
        span.mode-name(style="font-size: 1.8rem; font-weight: 700; color: #58a6ff;") #{mode.toUpperCase()}
      
      .stats-bar
        .stat-item
          span.label PUNTOS
          span#score-display.value 0
        .stat-item
          span.label PRECISIÓN
          span#accuracy-display.value 0%
        .stat-item
          span.label TIEMPO
          span#timer-display.value 30s

    // Pantalla de inicio
    #start-overlay
      .message-box
        h2(style="color: #58a6ff;") #{mode.toUpperCase()}
        p Prepárate para entrenar tu puntería.
        button#btn-start(onclick="comenzarJuego(event)") Empezar

    // El lienzo del juego
    canvas#gameCanvas(width="800" height="600" style="background: #000; display: block; margin: 0 auto;")
    
    // Pantalla de fin de partida
    #game-overlay.hidden
      .message-box
        h3(style="color: #58a6ff;") ¡Fin de la partida!
        p#final-stats Calculando puntuación...
        div(style="display: flex; gap: 1rem; flex-direction: column;")
          button(onclick="comenzarJuego(event)") Reintentar
          a.btn-home(href="/") Volver al Inicio

  // Cargamos el script del modo (gridshot.js o sixshot.js)
  script(src=`/js/${mode}.js`)

  script.
    const GAME_MODE = "#{mode}";
    const GAME_CONFIG = !{JSON.stringify(config)};
    
    function comenzarJuego(event) {
      if (event) {
        event.preventDefault();
        event.stopPropagation();
      }
      
      const startOverlay = document.getElementById('start-overlay');
      const gameOverlay = document.getElementById('game-overlay');

      // Ocultar capas con fuerza bruta
      if (startOverlay) startOverlay.style.setProperty('display', 'none', 'important');
      if (gameOverlay) {
        gameOverlay.classList.add('hidden');
        gameOverlay.style.setProperty('display', 'none', 'important');
      }
      
      console.log("Iniciando partida de " + GAME_MODE);
      
      if (typeof window.initGame === 'function') {
        window.initGame(); 
      }
    }

    async function saveGameResults(puntos, precision) {
      const finalStats = document.getElementById('final-stats');
      const gameOverlay = document.getElementById('game-overlay');

      if (finalStats) finalStats.innerText = `Puntos: ${puntos} | Precisión: ${precision}%`;
      
      if (gameOverlay) {
        gameOverlay.classList.remove('hidden');
        gameOverlay.style.setProperty('display', 'flex', 'important');
      }

      try {
        await fetch('/api/score', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            points: puntos,
            accuracy: precision,
            gameType: GAME_MODE
          })
        });
      } catch (error) {
        console.error("Error al guardar:", error);
      }
    }

    // Al cargar la página, aseguramos que el estado sea el correcto
    document.addEventListener('DOMContentLoaded', () => {
      const gameOverlay = document.getElementById('game-overlay');
      if (gameOverlay) gameOverlay.classList.add('hidden');
    });